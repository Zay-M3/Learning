---
// SearchBox pequeño para el header. Usa la UI de Pagefind.
// Pagefind sólo existe en el directorio `dist/pagefind/` tras el build,
// por eso el script sólo se inicializa en producción.
---
<form
  id="header-search"
  class="relative hidden md:block w-full max-w-sm"
  onsubmit="event.preventDefault(); window.location.href='/search';"
>
  <label for="header-search-input" class="sr-only">Buscar</label>
  <input
    id="header-search-input"
    type="search"
    name="q"
    placeholder="Buscar notas…"
    autocomplete="off"
    class="w-full rounded-md border border-zinc-200 bg-white px-3 py-1.5 pr-9 text-sm text-zinc-900 placeholder-zinc-400 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-100 dark:placeholder-zinc-500"
  />
  <svg
    class="pointer-events-none absolute right-2.5 top-1/2 h-4 w-4 -translate-y-1/2 text-zinc-400"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="2"
    stroke="currentColor"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
    />
  </svg>
</form>
