---
interface Props {
  tag: string;
  count?: number;
  size?: 'sm' | 'md';
}

const { tag, count, size = 'md' } = Astro.props;
const sizeCls =
  size === 'sm' ? 'text-xs px-2 py-0.5' : 'text-sm px-3 py-1';
---
<a
  href={`/tags/${encodeURIComponent(tag)}`}
  class={`inline-flex items-center gap-1.5 rounded-full border border-zinc-200 bg-zinc-50 text-zinc-700 transition-colors hover:border-blue-400 hover:bg-blue-50 hover:text-blue-700 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-200 dark:hover:border-blue-500 dark:hover:bg-blue-950 dark:hover:text-blue-300 ${sizeCls}`}
>
  <span>#{tag}</span>
  {count !== undefined && (
    <span class="text-zinc-500 dark:text-zinc-400">{count}</span>
  )}
</a>
