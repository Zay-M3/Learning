---
import { SESSIONS, type Session } from '../utils/posts.ts';
import { getPostsBySession, sessionLabel } from '../utils/posts.ts';
import BaseLayout from '../layouts/BaseLayout.astro';
import MarkdownCard from '../components/MarkdownCard.astro';
import fs from 'node:fs/promises';
import path from 'node:path';

export async function getStaticPaths() {
  return SESSIONS.map((session) => ({
    params: { session },
  }));
}

interface Props {
  session: Session;
}

interface NotebookMeta {
  type: 'notebook';
  slug: string;
  title: string;
  filename: string;
  description?: string;
  url: string;
  cells: number;
  size_kb?: number;
  language?: string;
}

interface FileMeta {
  type: 'file';
  slug: string;
  title: string;
  filename: string;
  language: string;
  lexer?: string;
  url: string;
  size_kb: number;
  extension: string;
}

interface BinaryMeta {
  type: 'binary';
  slug: string;
  title: string;
  filename: string;
  url: string;
  size_kb: number;
  extension: string;
}

type AssetMeta = NotebookMeta | FileMeta | BinaryMeta;

const { session: rawSession } = Astro.params;
const session = rawSession as Session;
const posts = await getPostsBySession(session);

// Leer _index.json para TODA sesión (no solo algoritmia)
let assets: AssetMeta[] = [];
try {
  const indexPath = path.resolve(
    process.cwd(),
    `public/${session}/_index.json`,
  );
  const raw = await fs.readFile(indexPath, 'utf-8');
  assets = JSON.parse(raw) as AssetMeta[];
} catch (e) {
  // _index.json puede no existir si el script assets.py no se ejecutó
  assets = [];
}

const notebooks = assets.filter(
  (a): a is NotebookMeta => a.type === 'notebook',
);
const files = assets.filter((a): a is FileMeta => a.type === 'file');
const binaries = assets.filter((a): a is BinaryMeta => a.type === 'binary');
---
<BaseLayout
  title={sessionLabel(session)}
  description={`Notas de la sesión ${sessionLabel(session)}`}
>
  <section>
    <nav class="mb-2 text-sm text-zinc-500">
      <a href="/" class="hover:underline">← Inicio</a>
    </nav>
    <h1
      class="mb-2 text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100"
    >
      {sessionLabel(session)}
    </h1>
    <p class="mb-8 text-zinc-600 dark:text-zinc-400">
      {posts.length} {posts.length === 1 ? 'nota' : 'notas'} en esta sesión.
    </p>

    {posts.length === 0 ? (
      <p class="text-sm text-zinc-500">Todavía no hay notas en esta sesión.</p>
    ) : (
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {posts.map((post) => <MarkdownCard post={post} />)}
      </div>
    )}

    {notebooks.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-4 text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
          📓 Notebooks
        </h2>
        <p class="mb-4 text-sm text-zinc-500 dark:text-zinc-400">
          Cuadernos Jupyter ejecutados y renderizados como HTML estático.
        </p>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          {notebooks.map((nb) => (
            <a
              href={nb.url}
              class="group block rounded-lg border border-zinc-200 bg-white p-5 transition hover:border-blue-500 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-blue-500"
            >
              <div class="mb-2 flex items-center gap-2">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded bg-orange-500 text-xs font-bold text-white">
                  📓
                </span>
                <h3 class="text-lg font-semibold text-zinc-900 group-hover:text-blue-600 dark:text-zinc-100 dark:group-hover:text-blue-400">
                  {nb.title}
                </h3>
              </div>
              <p class="mb-2 text-xs text-zinc-500 dark:text-zinc-400">
                {nb.filename} · {nb.cells} {nb.cells === 1 ? 'celda' : 'celdas'}
              </p>
              {nb.description && (
                <p class="text-sm text-zinc-600 line-clamp-3 dark:text-zinc-400">
                  {nb.description.replace(/^#+\s*/, '').replace(/\n/g, ' ').slice(0, 140)}
                  {nb.description.length > 140 ? '…' : ''}
                </p>
              )}
              <p class="mt-3 text-xs text-blue-600 dark:text-blue-400">Ver notebook →</p>
            </a>
          ))}
        </div>
      </section>
    )}

    {files.length > 0 && (
      <section class="mt-8">
        <h2 class="mb-4 text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
          📁 Archivos
        </h2>
        <p class="mb-4 text-sm text-zinc-500 dark:text-zinc-400">
          Archivos de código renderizados en pantalla con syntax highlighting.
        </p>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {files.map((f) => (
            <a
              href={f.url}
              class="group block rounded-lg border border-zinc-200 bg-white p-4 transition hover:border-blue-500 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-blue-500"
            >
              <div class="mb-2 flex items-center gap-2">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded bg-zinc-100 text-xs font-bold text-zinc-700 dark:bg-zinc-800 dark:text-zinc-300">
                  {f.extension === '.py' ? '🐍' : f.extension === '.json' ? '📋' : f.extension === '.md' ? '📝' : '📄'}
                </span>
                <h3 class="text-base font-semibold text-zinc-900 group-hover:text-blue-600 dark:text-zinc-100 dark:group-hover:text-blue-400">
                  {f.filename}
                </h3>
              </div>
              <p class="text-xs text-zinc-500 dark:text-zinc-400">
                {f.language} · {f.size_kb} KB
              </p>
            </a>
          ))}
        </div>
      </section>
    )}

    {binaries.length > 0 && (
      <section class="mt-8">
        <h2 class="mb-4 text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
          🖼️ Recursos
        </h2>
        <p class="mb-4 text-sm text-zinc-500 dark:text-zinc-400">
          Archivos binarios disponibles para descarga.
        </p>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {binaries.map((b) => (
            <a
              href={b.url}
              download
              class="group flex items-center justify-between gap-4 rounded-lg border border-zinc-200 bg-white p-4 transition hover:border-blue-500 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-blue-500"
            >
              <div class="flex items-center gap-3">
                <span class="inline-flex h-8 w-8 items-center justify-center rounded bg-purple-500 text-sm font-bold text-white">
                  🖼️
                </span>
                <div>
                  <p class="font-medium text-zinc-900 dark:text-zinc-100">{b.filename}</p>
                  <p class="text-xs text-zinc-500 dark:text-zinc-400">{b.size_kb} KB</p>
                </div>
              </div>
              <span class="text-xs text-blue-600 dark:text-blue-400">Descargar ↓</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </section>
</BaseLayout>