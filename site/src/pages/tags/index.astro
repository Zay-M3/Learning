---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagChip from '../../components/TagChip.astro';
import { getAllTags } from '../../utils/posts.ts';

const tagsMap = await getAllTags();
const tags = [...tagsMap.entries()].sort((a, b) => {
  // primero por count desc, luego alfabético asc
  if (b[1] !== a[1]) return b[1] - a[1];
  return a[0].localeCompare(b[0], 'es');
});
---
<BaseLayout title="Tags" description="Todos los tags">
  <section>
    <h1
      class="mb-2 text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100"
    >
      Tags
    </h1>
    <p class="mb-8 text-zinc-600 dark:text-zinc-400">
      {tags.length} {tags.length === 1 ? 'tag' : 'tags'} en total.
    </p>

    {tags.length === 0 ? (
      <p class="text-sm text-zinc-500">Todavía no hay tags asignados.</p>
    ) : (
      <div class="flex flex-wrap gap-2">
        {tags.map(([tag, count]) => (
          <TagChip tag={tag} count={count} />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
